POSTGRES_PASSWORD=change-this-db-password

DATABASE_DSN=postgresql://radius_totp:change-this-db-password@postgres:5432/radius_totp
FERNET_KEY=replace-with-generated-fernet-key

# For local demo without Active Directory.
AUTH_BACKEND=local
LOCAL_USERS=demo.user:DemoPassword123

# For real AD later, switch AUTH_BACKEND=ad and fill these fields.
AD_SERVER=
AD_PORT=636
AD_USE_SSL=true
AD_START_TLS=false
AD_TLS_VALIDATE=true
AD_BASE_DN=
AD_USER_UPN_SUFFIX=
AD_BIND_DN=
AD_BIND_PASSWORD=

RADIUS_LISTEN_HOST=0.0.0.0
RADIUS_AUTH_PORT=1812
RADIUS_DICTIONARY=radius/dictionary

# Format: client_ip:shared_secret:name
# Add only trusted VPN/RD Gateway/test host public IPs here.
RADIUS_CLIENTS=127.0.0.1:testing123:local

OTP_ISSUER=Demo VPN
OTP_VALID_WINDOW=1
ENABLE_PASSWORD_OTP=true
ENABLE_ACCESS_CHALLENGE=true
